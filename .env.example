# ============================================
# Synkra AIOX Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_DATABASE_URL=
SUPABASE_EDGE_FUNCTIONS_URL=

# Public Supabase values exposed to Vite frontend.
# Never expose SUPABASE_SERVICE_ROLE_KEY in VITE_* variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_EDGE_FUNCTIONS_URL=

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9

# --------------------------------------------
# Mascot Wars - App Configuration
# --------------------------------------------
APP_NAME="Mascot Wars"
APP_ENV=local
APP_URL=http://127.0.0.1:5173
APP_PUBLIC_URL=http://127.0.0.1:5173
APP_SUPPORT_EMAIL=
BACKEND_API_URL=http://127.0.0.1:54321/functions/v1

# Vite public app configuration
VITE_APP_NAME="Mascot Wars"
VITE_APP_ENV=local
VITE_APP_URL=http://127.0.0.1:5173
VITE_APP_PUBLIC_URL=http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:54321/functions/v1
VITE_ENABLE_MOCKS=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PREDICTIONS=false
VITE_ENABLE_REAL_MST=false
# Set true only when you want predictions to bypass Solana and write local DB test rows.
VITE_PREDICTION_DB_ONLY=false
VITE_SUPPORT_EMAIL=

# --------------------------------------------
# Mascot Wars - Solana / MST
# --------------------------------------------
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed
SOLANA_INDEXER_URL=
SOLANA_EXPLORER_BASE_URL=https://explorer.solana.com

# MST token. Fill these after creating the token/mint.
MST_MINT_ADDRESS=
MST_TOKEN_DECIMALS=9
MST_TOKEN_SYMBOL=MST
MST_TOKEN_NAME="Mascot Wars Token"
MST_TREASURY_WALLET=
MST_VAULT_WALLET=
MST_PREDICTION_PROGRAM_ID=
MST_PACKS_PROGRAM_ID=

# --------------------------------------------
# Edge Function backend secrets (server-side only — NEVER prefix with VITE_)
# Set via: supabase secrets set KEY=value
# --------------------------------------------
# Custodial model: ALL prediction stakes (SOL) go to this single wallet. The platform holds
# the stakes here and pays winners out MANUALLY after each match (no on-chain prediction program).
# Keep this wallet's private key safe — it holds every open stake.
PREDICTIONS_SOL_WALLET=
# (Legacy on-chain fee wallets — only used if you re-enable the smart-contract model.)
MST_TREASURY_SOL_WALLET=
PRIZE_POOL_SOL_WALLET=
# JSON byte arrays of the server-held keypairs (from .secrets/devnet/*.json).
SETTLEMENT_AUTHORITY_KEYPAIR=
MST_TREASURY_KEYPAIR=
# config.authority (= deployer) keypair — signs create_pool. From .secrets/devnet/deployer.json
POOL_AUTHORITY_KEYPAIR=
# On-chain per-entry hard ceiling in SOL (last-line guard; backend enforces finer caps).
POOL_HARD_MAX_STAKE_SOL=10
# Prediction staking bounds (SOL) + the $MASCOTS hold required to predict (off-chain gate).
MIN_STAKE_SOL=0.1
MAX_STAKE_SOL=10
PREDICTION_MIN_HOLD_MST=50000
# Shared secret required by cron-triggered functions
# (payout-referrals, ingest-fixtures, lock-pools, oracle-poll, create-pool).
CRON_SECRET=
# Service role key is consumed by Edge Functions for trusted writes.
# SUPABASE_SERVICE_ROLE_KEY is defined in the Supabase section above.

# --------------------------------------------
# Mascot Wars - Sports data (API-Football / RapidAPI) + oracle
# --------------------------------------------
# Key from RapidAPI (https://rapidapi.com/api-sports/api/api-football) or
# api-sports.io. HOST: "v3.football.api-sports.io" (direct) or the RapidAPI host.
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
# League + season to ingest (e.g. World Cup league id + year). National-team comp.
API_FOOTBALL_LEAGUE_ID=
API_FOOTBALL_SEASON=
# How many days ahead ingest-fixtures pulls upcoming fixtures.
INGEST_WINDOW_DAYS=14
# Minutes a fetched result waits (dispute window) before automatic settlement.
ORACLE_DISPUTE_MINUTES=15

# Public Solana/MST values for Vite frontend.
# Use a DEDICATED devnet RPC (Helius/QuickNode/Alchemy) — the public
# api.devnet.solana.com rate-limits/blocks browser requests and causes
# intermittent "Network/RPC issue reaching Solana" purchase failures.
VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_DEVNET_KEY
VITE_SOLANA_COMMITMENT=confirmed
VITE_SOLANA_EXPLORER_BASE_URL=https://explorer.solana.com
VITE_MST_MINT_ADDRESS=
VITE_MST_TOKEN_DECIMALS=9
VITE_MST_TOKEN_SYMBOL=MST
VITE_MST_TREASURY_WALLET=
# Prediction program id (needed for on-chain PDA derivation + user-signed claims).
VITE_MST_PREDICTION_PROGRAM_ID=
# Predictions are staked in native SOL: flat min/max stake (SOL) + the $MASCOTS hold gate.
# A wallet must HOLD >= VITE_PREDICTION_MIN_HOLD_MST $MASCOTS to unlock staking (Step 3).
VITE_MIN_STAKE_SOL=0.1
VITE_MAX_STAKE_SOL=10
VITE_PREDICTION_MIN_HOLD_MST=50000

# --------------------------------------------
# Mascot Wars - Wallets / Swap
# --------------------------------------------
VITE_ENABLE_PHANTOM=true
VITE_ENABLE_SOLFLARE=false
VITE_WALLET_CONNECT_PROJECT_ID=

JUPITER_QUOTE_API_URL=https://quote-api.jup.ag/v6
JUPITER_SWAP_API_URL=https://quote-api.jup.ag/v6/swap
RAYDIUM_SWAP_URL=https://raydium.io/swap/

VITE_JUPITER_SWAP_URL=
VITE_RAYDIUM_SWAP_URL=https://raydium.io/swap/
VITE_BUY_MST_URL=

# --------------------------------------------
# Mascot Wars - Assets / Storage
# --------------------------------------------
SUPABASE_STORAGE_BUCKET_MASCOTS=mascots
SUPABASE_STORAGE_BUCKET_PACKS=packs
SUPABASE_STORAGE_BUCKET_CARDS=cards

ASSETS_BASE_URL=http://127.0.0.1:5173/assets
VITE_ASSETS_BASE_URL=http://127.0.0.1:5173/assets
VITE_MASCOT_ASSETS_BASE_URL=http://127.0.0.1:5173/assets/mascots

# Optional future Cloudflare Pages/R2/CDN.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=
VITE_CDN_ASSETS_URL=

# --------------------------------------------
# Mascot Wars - Compliance / Feature Gates
# --------------------------------------------
MINIMUM_USER_AGE=18
VITE_MINIMUM_USER_AGE=18
VITE_SHOW_RISK_WARNINGS=true
VITE_REQUIRE_WALLET_FOR_APP=true
VITE_ALLOW_REAL_MONEY_COPY=false
VITE_BLOCKED_REGIONS=
VITE_ALLOWED_REGIONS=

# --------------------------------------------
# Mascot Wars - Analytics / Monitoring
# --------------------------------------------
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_GA_MEASUREMENT_ID=
