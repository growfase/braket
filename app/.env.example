# Frontend config — copy to .env and fill in. Only VITE_* vars reach the browser.
# NEVER put the Supabase service_role key here (server-side only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_POOL_WALLET=
# Dedicated mainnet RPC (embedded in the client bundle — restrict the key by domain).
VITE_SOLANA_RPC_URL=
